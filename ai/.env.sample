# Port the service listens on (default 5176)
PORT=5176

# Required: the calling service shares this exact value as `X-AI-Secret`
# on every request. Reject any request that doesn't match.
AI_SERVICE_SECRET=

# Required: the Hocuspocus server shares this exact value as the bearer
# token for the AI service principal, so this service can join `docx:*`
# rooms without a per-user firebase token.
HOCUSPOCUS_AI_SERVICE_SECRET=

# Required: WS URL of the Hocuspocus server (same one the shell uses).
# Dev:  ws://localhost:2000
# Prod: e.g. wss://ws.example.com
HOCUSPOCUS_URL=ws://localhost:2000

# Optional: cap pool size for warm room connections (default 16)
AI_HOCUSPOCUS_POOL_MAX=16

# Optional: idle close timeout for pooled connections, ms (default 300000 = 5 min)
AI_HOCUSPOCUS_POOL_IDLE_MS=300000

# Optional: max time to wait for initial hocuspocus sync, ms (default 10000)
AI_HOCUSPOCUS_CONNECT_MS=10000

# Optional: request body limit MB (default 5)
AI_SERVICE_BODY_LIMIT_MB=5
