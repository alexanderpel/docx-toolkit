# Port the service listens on (default 5175).
PORT=5175

# Shared secret the calling service must include in the `X-Converter-Secret`
# header. Leave blank for unauthenticated dev. In prod, generate with:
#   openssl rand -base64 32
CONVERTER_SHARED_SECRET=

# CORS allowed origin (default "*" — fine when running behind a reverse
# proxy that locks down ingress; tighten to a specific origin if you
# expose this service directly).
CONVERTER_ALLOWED_ORIGIN=*

# Max request body size in MB (default 50). Bumps the express body limit
# to accommodate larger .docx uploads.
CONVERTER_BODY_LIMIT_MB=50
